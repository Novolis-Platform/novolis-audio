<Project>
  <Target Name="CopyNovolisAudioNativeAssets" AfterTargets="Build">
    <ItemGroup>
      <_NovolisAudioNativeRuntime Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\*" Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
      <_NovolisAudioNativeRuntime Include="$(MSBuildThisFileDirectory)..\runtimes\linux-x64\native\*" Condition="$([MSBuild]::IsOSPlatform('Linux'))" />
      <_NovolisAudioNativeRuntime Include="$(MSBuildThisFileDirectory)..\runtimes\osx-x64\native\*" Condition="$([MSBuild]::IsOSPlatform('OSX')) or $([MSBuild]::IsOSPlatform('Darwin'))" />
    </ItemGroup>
    <Copy
      SourceFiles="@(_NovolisAudioNativeRuntime)"
      DestinationFolder="$(OutputPath)"
      SkipUnchangedFiles="true"
      Condition="'@(_NovolisAudioNativeRuntime)' != ''" />
  </Target>
</Project>
