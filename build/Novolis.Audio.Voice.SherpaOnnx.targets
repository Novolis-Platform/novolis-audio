<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <_NovolisVoiceModelZipName>en-us-piper-amy.zip</_NovolisVoiceModelZipName>
    <_NovolisVoiceModelProfileDir>en-us-piper-amy</_NovolisVoiceModelProfileDir>
    <_NovolisVoiceModelsOut>$(OutDir)models\$(_NovolisVoiceModelProfileDir)\</_NovolisVoiceModelsOut>
    <_NovolisVoiceModelZipInPackage>$(MSBuildThisFileDirectory)..\contentFiles\any\any\models\$(_NovolisVoiceModelZipName)</_NovolisVoiceModelZipInPackage>
    <_NovolisVoiceModelZipInOutput>$(OutDir)models\$(_NovolisVoiceModelZipName)</_NovolisVoiceModelZipInOutput>
  </PropertyGroup>

  <Target Name="ExtractNovolisBundledVoiceModels"
          AfterTargets="ResolveReferences"
          Condition="'$(DisableNovolisBundledVoiceModels)' != 'true' and !Exists('$(_NovolisVoiceModelsOut)tokens.txt')">
    <PropertyGroup>
      <_NovolisVoiceModelZip Condition="Exists('$(_NovolisVoiceModelZipInOutput)')">$(_NovolisVoiceModelZipInOutput)</_NovolisVoiceModelZip>
      <_NovolisVoiceModelZip Condition="'$(_NovolisVoiceModelZip)' == '' and Exists('$(_NovolisVoiceModelZipInPackage)')">$(_NovolisVoiceModelZipInPackage)</_NovolisVoiceModelZip>
    </PropertyGroup>
    <Error Condition="'$(_NovolisVoiceModelZip)' == ''"
           Text="Novolis.Audio.Voice.SherpaOnnx: missing bundled model zip (restore a current 2026.1.* package from GitHub Packages)." />
    <MakeDir Directories="$(_NovolisVoiceModelsOut)" />
    <Exec Command="powershell -NoProfile -Command &quot;Expand-Archive -LiteralPath '$(_NovolisVoiceModelZip)' -DestinationPath '$(_NovolisVoiceModelsOut)' -Force&quot;" />
  </Target>
</Project>
