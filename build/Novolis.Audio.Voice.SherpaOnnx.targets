<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <_NovolisBundledVoiceModelIds>en-us-piper-amy;en-us-piper-lessac-low;en-us-piper-kristin-medium</_NovolisBundledVoiceModelIds>
    <_NovolisVoiceModelsOutRoot>$(OutDir)models</_NovolisVoiceModelsOutRoot>
  </PropertyGroup>

  <Target Name="ExtractNovolisBundledVoiceModels"
          AfterTargets="ResolveReferences"
          Condition="'$(DisableNovolisBundledVoiceModels)' != 'true'">
    <PropertyGroup>
      <_NovolisExtractVoiceModelsScript>$(MSBuildThisFileDirectory)scripts/extract-bundled-voice-models.ps1</_NovolisExtractVoiceModelsScript>
    </PropertyGroup>

    <Error Condition="!Exists('$(_NovolisExtractVoiceModelsScript)')"
           Text="Novolis.Audio.Voice.SherpaOnnx: missing extract script at $(_NovolisExtractVoiceModelsScript)." />

    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(_NovolisExtractVoiceModelsScript)&quot; -OutputDir &quot;$(OutDir.TrimEnd('\'))&quot;" />

    <Error Condition="!Exists('$(_NovolisVoiceModelsOutRoot)\en-us-piper-amy\tokens.txt')"
           Text="Novolis.Audio.Voice.SherpaOnnx: missing bundled models (restore Novolis.Audio.Voice.SherpaOnnx from GitHub Packages or build novolis-audio with models present)." />
  </Target>
</Project>
