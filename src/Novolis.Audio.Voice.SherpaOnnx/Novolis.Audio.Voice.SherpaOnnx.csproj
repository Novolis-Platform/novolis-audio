<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="$(MSBuildThisFileDirectory)..\..\build\Novolis.Audio.Packaging.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Novolis.Audio.Voice.SherpaOnnx</RootNamespace>
    <AssemblyName>Novolis.Audio.Voice.SherpaOnnx</AssemblyName>
    <PackageId>Novolis.Audio.Voice.SherpaOnnx</PackageId>
    <IsPackable>true</IsPackable>
    <Description>Sherpa-ONNX offline TTS with bundled Piper en-us-piper-amy model.</Description>
    <BundledModelFolderName>en-us-piper-amy</BundledModelFolderName>
    <VoiceModelZip>$(MSBuildThisFileDirectory)..\..\artifacts\voice-model-en-us-piper-amy.zip</VoiceModelZip>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="org.k2fsa.sherpa.onnx" />
  </ItemGroup>

  <Target Name="CreateVoiceModelZip" BeforeTargets="PrepareForBuild"
          Condition="Exists('..\..\models\$(BundledModelFolderName)\tokens.txt') and !Exists('$(VoiceModelZip)')">
    <Exec Command="pwsh -NoProfile -File &quot;$(MSBuildThisFileDirectory)..\..\scripts\pack-voice-model-archive.ps1&quot;" />
  </Target>

  <ItemGroup Condition="Exists('$(VoiceModelZip)')">
    <None Include="$(VoiceModelZip)">
      <Pack>true</Pack>
      <PackagePath>contentFiles/any/any/models/$(BundledModelFolderName).zip</PackagePath>
      <PackageCopyToOutput>true</PackageCopyToOutput>
    </None>
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\build\Novolis.Audio.Voice.SherpaOnnx.targets"
          Pack="true"
          PackagePath="buildTransitive/Novolis.Audio.Voice.SherpaOnnx.targets" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Novolis.Audio.Voice.Abstractions\Novolis.Audio.Voice.Abstractions.csproj" />
  </ItemGroup>

</Project>
