<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="$(MSBuildThisFileDirectory)..\..\build\Novolis.Audio.Packaging.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Novolis.Audio.Voice.SherpaOnnx</RootNamespace>
    <AssemblyName>Novolis.Audio.Voice.SherpaOnnx</AssemblyName>
    <PackageId>Novolis.Audio.Voice.SherpaOnnx</PackageId>
    <IsPackable>true</IsPackable>
    <Description>Sherpa-ONNX offline TTS with bundled Piper en-us-piper-amy model.</Description>
    <BundledModelFolderName>en-us-piper-amy</BundledModelFolderName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="org.k2fsa.sherpa.onnx" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\..\models\en-us-piper-amy\**\*"
             Condition="Exists('..\..\models\en-us-piper-amy\tokens.txt')">
      <Link>models\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <PackageCopyToOutput>true</PackageCopyToOutput>
      <PackagePath>contentFiles/any/any/models/$(BundledModelFolderName)/%(RecursiveDir)%(Filename)%(Extension)</PackagePath>
      <Pack>true</Pack>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Novolis.Audio.Voice.Abstractions\Novolis.Audio.Voice.Abstractions.csproj" />
  </ItemGroup>

</Project>
