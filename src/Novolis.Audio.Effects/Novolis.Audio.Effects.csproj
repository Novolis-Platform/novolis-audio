<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="$(MSBuildThisFileDirectory)..\..\build\Novolis.Audio.Packaging.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Novolis.Audio.Effects</RootNamespace>
    <AssemblyName>Novolis.Audio.Effects</AssemblyName>
    <PackageId>Novolis.Audio.Effects</PackageId>
    <IsPackable>true</IsPackable>
    <Description>PCM effect chains for voice and playback pipelines.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Novolis.Audio.Core\Novolis.Audio.Core.csproj" />
  </ItemGroup>

</Project>
